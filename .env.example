# ============================================================
# FlyAgent Environment Variables
# Copy this to .env and fill in your keys
# ============================================================

# Required: Google AI API key (for Gemini models)
GOOGLE_API_KEY=your-google-api-key-here

# Optional: Override model tiers from config.toml
# FLYAGENT_FAST_MODEL=gemini-2.0-flash
# FLYAGENT_BALANCED_MODEL=gemini-2.5-flash
# FLYAGENT_POWERFUL_MODEL=gemini-2.5-pro

# Optional: Override orchestrator settings
# FLYAGENT_MAX_ATTEMPTS=12
# FLYAGENT_MAX_CONCURRENT=3
# FLYAGENT_VERBOSE=true
